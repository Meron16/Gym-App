# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database (docker: infra/docker-compose.yml) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gym?schema=public"

# --- Redis (Phase 1+ cache / rate limit; wire later) ---
REDIS_URL="redis://localhost:6379"

# --- JWT (app session after Firebase or dev login) ---
JWT_SECRET="replace-with-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# --- Firebase Admin (Phase 2) — paste service account fields ---
# Leave empty to use dev token mode (see AUTH_DEV_* below).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use literal \n for newlines in the key, or point to GOOGLE_APPLICATION_CREDENTIALS file.
FIREBASE_PRIVATE_KEY=

# Optional: path to service account JSON instead of the three vars above
GOOGLE_APPLICATION_CREDENTIALS=

# --- Dev auth (only when Firebase is NOT configured) ---
# When true, POST /auth/firebase-login accepts idToken "dev" / "placeholder" and returns a real JWT.
AUTH_DEV_ALLOW_PLACEHOLDER_TOKEN=true

# --- Bookings ---
# When true and DB is up, user must have an active Subscription row to book.
BOOKING_REQUIRE_ENTITLEMENT=false
BOOKING_SLOT_CAPACITY=10

# --- Stripe (Phase 5) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for Checkout (e.g. price_xxx) — required for real Stripe sessions
STRIPE_CHECKOUT_PRICE_ID=
STRIPE_SUCCESS_URL=https://example.com/billing/success
STRIPE_CANCEL_URL=https://example.com/billing/cancel
# Fallback checkout URL when Stripe is not configured (UI demo only)
STRIPE_CHECKOUT_PLACEHOLDER_URL=https://example.com/stripe-checkout-placeholder

# --- Observability (Phase 9) ---
SENTRY_DSN=
MIXPANEL_TOKEN=

# --- Admin / CORS (optional) ---
# Comma-separated origins for browser admin app
CORS_ORIGINS=
