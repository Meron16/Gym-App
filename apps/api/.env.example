# --- Server ---
PORT=3001
NODE_ENV=development

# --- PostgreSQL (required) — any host: local install, Docker (infra/docker-compose.yml), Neon, RDS, etc. ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gym?schema=public"
# Neon: prefer the *-pooler* connection string from the dashboard. The API auto-appends pgbouncer=true, connection_limit, timeouts for *.neon.tech hosts.

# --- Email/password auth (no Firebase) ---
# POST /auth/register  body: { "email","password","fullName?","phone?" }  → User row + JWT
# POST /auth/login     body: { "email","password" }

# --- JWT (app session after Firebase or dev login) ---
JWT_SECRET="replace-with-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# --- Firebase Admin (Phase 2) — paste service account fields ---
# Leave empty to use dev token mode (see AUTH_DEV_* below).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use literal \n for newlines in the key, or point to GOOGLE_APPLICATION_CREDENTIALS file.
FIREBASE_PRIVATE_KEY=

# Optional: path to service account JSON instead of the three vars above
GOOGLE_APPLICATION_CREDENTIALS=

# --- Dev auth (only when Firebase is NOT configured) ---
# When true, POST /auth/firebase-login accepts idToken "dev" / "placeholder" and returns a real JWT.
AUTH_DEV_ALLOW_PLACEHOLDER_TOKEN=false

# --- Bookings ---
# When true and DB is up, user must have an active Subscription row to book.
BOOKING_REQUIRE_ENTITLEMENT=false
BOOKING_SLOT_CAPACITY=10

# --- Stripe (Phase 5) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Default Price ID for Checkout (price_xxx) if Package.stripePriceId is not set in DB
STRIPE_CHECKOUT_PRICE_ID=
# Optional: set stripePriceId per row in Package (via admin or SQL) for different plans
STRIPE_SUCCESS_URL=https://example.com/billing/success
STRIPE_CANCEL_URL=https://example.com/billing/cancel
# Fallback checkout URL when Stripe is not configured (UI demo only)
STRIPE_CHECKOUT_PLACEHOLDER_URL=https://example.com/stripe-checkout-placeholder

# --- Product analytics (Phase 6) ---
# POST /analytics/track persists to AnalyticsEvent (no extra env). Admin: GET /admin/analytics/summary

# --- Observability (Phase 9) ---
SENTRY_DSN=
MIXPANEL_TOKEN=

# --- Admin / CORS (optional) ---
# Comma-separated origins for browser admin app
CORS_ORIGINS=

# OpenStreetMap gym import (operator/admin JWT):
#   POST /admin/gyms/sync-osm  body: { "location": "Addis Ababa, Ethiopia" }
