generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  operator
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  firebaseUid  String?  @unique
  /** Bcrypt hash for email/password auth (null when user only uses Firebase). */
  passwordHash String?
  phone        String?
  displayName  String?
  role         UserRole @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings             Booking[]
  subscriptions        Subscription[]
  notificationTokens NotificationToken[]
  trainerBookings      TrainerBooking[]
  workoutEvents        WorkoutEvent[]
}

model Gym {
  id             String   @id @default(cuid())
  name           String
  location       String
  address        String
  rating         Float    @default(4.2)
  priceFrom      String   @default("$—")
  tag            String   @default("Fitness")
  capacityBase   Int      @default(45)
  lat            Float
  lng            Float
  amenities      Json
  operatingHours Json
  photos         Json
  osmType        String?
  osmId          String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
  trainers Trainer[]
}

model Trainer {
  id           String   @id @default(cuid())
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name         String
  tagline      String   @default("")
  expertise    Json
  /** Weekly schedule: [{ "day": "Mon", "slots": ["06:30", "09:00"] }, ...] */
  availability Json
  photoUrl     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings TrainerBooking[]

  @@index([gymId])
}

model TrainerBooking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  slotId    String
  status    String
  createdAt DateTime @default(now())

  @@index([trainerId, slotId, status])
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  slotId    String
  status    String
  createdAt DateTime @default(now())

  @@index([gymId, slotId, status])
}

model Package {
  id                 String @id @default(cuid())
  name               String
  priceCents         Int
  billing            String
  maxSessions        Int    @default(999)
  highlights         Json
  maxSessionsPerWeek Int    @default(3)
  /** Stripe Price ID (price_xxx) for Checkout; falls back to STRIPE_CHECKOUT_PRICE_ID env when null */
  stripePriceId      String?
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PaymentRecord {
  id          String   @id @default(cuid())
  userId      String
  amountCents Int
  provider    String
  externalId  String?
  createdAt   DateTime @default(now())
}

model NotificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  platform  String?
  createdAt DateTime @default(now())
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String?
  channel   String
  payload   String
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  props     String?
  createdAt DateTime @default(now())
}

/** Logged workouts for Pulse streak / charts / gamification */
model WorkoutEvent {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind             String   @default("workout")
  durationMinutes  Int?
  caloriesEstimate Int?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

/** Stripe webhook idempotency — safe replays */
model ProcessedStripeEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  eventType       String?
  createdAt       DateTime @default(now())
}

/** Minimal audit trail for admin / sensitive actions */
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}
