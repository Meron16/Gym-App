# Public API base for browser calls (same machine: localhost)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dev-only admin login token for API /auth/firebase-login
# Use "admin" to get admin role when API runs with AUTH_DEV_ALLOW_PLACEHOLDER_TOKEN=true
NEXT_PUBLIC_ADMIN_DEV_TOKEN=admin

# Phase 8+: Firebase web / NextAuth / custom admin JWT — placeholders
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
ADMIN_JWT_SECRET=
